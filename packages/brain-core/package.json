{
  "name": "@quackstro/brain-core",
  "version": "2026.3.5",
  "private": true,
  "description": "Generic bucket-based memory system for OpenClaw with LLM classification, semantic search, auto-capture, and auto-recall.",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./store": "./store.ts",
    "./schemas": "./schemas.ts",
    "./classifier": "./classifier.ts",
    "./embeddings": "./embeddings.ts",
    "./tag-parser": "./tag-parser.ts",
    "./audit": "./audit.ts",
    "./router": "./router.ts",
    "./commands/drop": "./commands/drop.ts",
    "./commands/fix": "./commands/fix.ts",
    "./commands/recall": "./commands/recall.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@sinclair/typebox": "0.34.48"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
