{
    "id": "brain",
    "kind": "service",
    "uiHints": {
        "embedding.apiKey": {
            "label": "Embedding API Key",
            "sensitive": true,
            "placeholder": "gho_...",
            "help": "API key for embeddings (reuse from doc-RAG)"
        },
        "embedding.model": {
            "label": "Embedding Model",
            "placeholder": "text-embedding-3-small",
            "help": "OpenAI embedding model to use"
        },
        "classification.model": {
            "label": "Classification Model",
            "placeholder": "anthropic/claude-sonnet-4",
            "help": "LLM model for thought classification"
        },
        "classification.confidenceThreshold": {
            "label": "Confidence Threshold",
            "help": "Minimum confidence to auto-route (0.0-1.0, default 0.80)"
        }
    },
    "configSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "embedding": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "apiKey": {
                        "type": "string"
                    },
                    "model": {
                        "type": "string",
                        "enum": [
                            "text-embedding-3-small",
                            "text-embedding-3-large",
                            "gemini-embedding-001"
                        ]
                    },
                    "baseURL": {
                        "type": "string"
                    }
                },
                "required": [
                    "apiKey"
                ]
            },
            "storage": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "dbPath": {
                        "type": "string"
                    }
                }
            },
            "classification": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "model": {
                        "type": "string"
                    },
                    "confidenceThreshold": {
                        "type": "number"
                    },
                    "apiKey": {
                        "type": "string"
                    }
                }
            },
            "digests": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "enabled": {
                        "type": "boolean"
                    },
                    "timezone": {
                        "type": "string"
                    },
                    "schedule": {
                        "type": "object",
                        "properties": {
                            "morning": {
                                "type": "object",
                                "properties": {
                                    "enabled": {
                                        "type": "boolean"
                                    },
                                    "time": {
                                        "type": "string"
                                    },
                                    "maxWords": {
                                        "type": "number"
                                    }
                                }
                            },
                            "midday": {
                                "type": "object",
                                "properties": {
                                    "enabled": {
                                        "type": "boolean"
                                    },
                                    "time": {
                                        "type": "string"
                                    },
                                    "maxWords": {
                                        "type": "number"
                                    }
                                }
                            },
                            "afternoon": {
                                "type": "object",
                                "properties": {
                                    "enabled": {
                                        "type": "boolean"
                                    },
                                    "time": {
                                        "type": "string"
                                    },
                                    "maxWords": {
                                        "type": "number"
                                    }
                                }
                            },
                            "night": {
                                "type": "object",
                                "properties": {
                                    "enabled": {
                                        "type": "boolean"
                                    },
                                    "time": {
                                        "type": "string"
                                    },
                                    "maxWords": {
                                        "type": "number"
                                    }
                                }
                            },
                            "weekly": {
                                "type": "object",
                                "properties": {
                                    "enabled": {
                                        "type": "boolean"
                                    },
                                    "day": {
                                        "type": "string"
                                    },
                                    "time": {
                                        "type": "string"
                                    },
                                    "maxWords": {
                                        "type": "number"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "dnd": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "autoQuiet": {
                        "type": "object",
                        "properties": {
                            "enabled": {
                                "type": "boolean"
                            },
                            "from": {
                                "type": "string"
                            },
                            "to": {
                                "type": "string"
                            }
                        }
                    },
                    "manual": {
                        "type": "boolean"
                    }
                }
            },
            "usageAware": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "enabled": {
                        "type": "boolean"
                    },
                    "backoffThreshold": {
                        "type": "number"
                    }
                }
            }
        }
    }
}